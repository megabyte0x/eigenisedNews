{
  "name": "eigenised-news",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build:frontend": "node scripts/build-frontend.mjs dist/public",
    "dev:frontend": "node scripts/build-frontend.mjs public --watch",
    "build": "npm run build:frontend && esbuild src/index.ts --bundle --platform=node --target=node25 --format=cjs --outfile=dist/bundle.cjs",
    "start": "node dist/bundle.cjs",
    "dev": "sh -c 'npm run dev:frontend & tsx watch src/index.ts'",
    "e2e:live": "node scripts/live-e2e.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@layr-labs/ai-gateway-provider": "^1.0.1",
    "ai": "^6.0.168",
    "express": "^5.2.1",
    "viem": "^2.48.4"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/supertest": "^6.0.2",
    "esbuild": "^0.28.0",
    "jsdom": "^29.1.1",
    "supertest": "^7.0.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
