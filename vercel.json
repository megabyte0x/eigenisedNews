{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build:frontend",
  "outputDirectory": "dist/public",
  "rewrites": [
    {
      "source": "/",
      "destination": "/index.html"
    },
    {
      "source": "/research",
      "destination": "http://35.204.200.15:3000/research"
    },
    {
      "source": "/research/:path*",
      "destination": "http://35.204.200.15:3000/research/:path*"
    },
    {
      "source": "/api/research",
      "destination": "http://35.204.200.15:3000/api/research"
    },
    {
      "source": "/synthesize",
      "destination": "http://35.204.200.15:3000/synthesize"
    },
    {
      "source": "/openapi.json",
      "destination": "http://35.204.200.15:3000/openapi.json"
    },
    {
      "source": "/.well-known/x402",
      "destination": "http://35.204.200.15:3000/.well-known/x402"
    },
    {
      "source": "/verify",
      "destination": "http://35.204.200.15:3000/verify"
    },
    {
      "source": "/skill.md",
      "destination": "http://35.204.200.15:3000/skill.md"
    },
    {
      "source": "/healthz",
      "destination": "http://35.204.200.15:3000/healthz"
    }
  ]
}
