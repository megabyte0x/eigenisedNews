# Server
PORT=3000

# Auto-set by EigenCompute appWallet.bindEnv at runtime.
# Local dev: set to a 32-byte hex private key (does NOT need to match the deployed agent).
AGENT_PRIVATE_KEY=0x_local_dev_only

# Auto-set by EigenCompute platform at runtime.
# Local dev: leave as "local"; the agent address is derived from AGENT_PRIVATE_KEY.
AGENT_ID=local
EIGEN_APP_ID=local
EIGEN_IMAGE_DIGEST=local
EIGEN_COMMIT_SHA=local
# local, sepolia, or mainnet-alpha
EIGEN_ENVIRONMENT=local

# LLM Proxy: no API key needed. Auth is automatic via TEE attestation when deployed.
# Canonical override name: EIGEN_GATEWAY_URL. Leave it unset for ordinary local dev.
# On mainnet-alpha, Eigen recommends:
# EIGEN_GATEWAY_URL=https://ai-gateway.eigencloud.xyz
# Older probe tooling may still accept EIGEN_GATEWAY_BASE_URL as a fallback alias.
EIGEN_GATEWAY_URL=

# Optional primary article-access fetcher. When set, article URLs are scraped
# through Firecrawl `/v2/scrape` first; direct bounded HTTP is used as fallback.
FIRECRAWL_API_KEY=
# FIRECRAWL_API_URL=https://api.firecrawl.dev

# Browser UI / CORS
# FRONTEND_API_BASE_URL points the browser UI at a remote backend.
FRONTEND_API_BASE_URL=
# Comma-separated browser origins that may call API routes and read payment headers.
# Example: CORS_ALLOW_ORIGINS=http://localhost:5173,https://agents.example
CORS_ALLOW_ORIGINS=

# Service identity advertised by /verify and /openapi.json.
SERVICE_NAME=eigenisedNews-paid-research
SERVICE_VERSION=0.1.0
# Public origin used in x402/MPP challenges when behind a proxy/custom domain.
# Example: BASE_URL=https://research.example.com
BASE_URL=

# Paid agent API: POST /api/research guarded by dual402.
# auto = enable only when all payment env vars are present.
# true = fail closed at boot if payment env vars are incomplete.
# false = disable the paid endpoint.
PAID_RESEARCH_ENABLED=auto
PAID_RESEARCH_PRICE_USDC=0.05
PAID_RESEARCH_WAIT_FOR_SETTLE=false
PAID_RESEARCH_DESCRIPTION=Eigenised news article research by pro and contra AI agents.

# Shared recipient used by both MPP_RECIPIENT and X402_PAYEE_ADDRESS when those
# protocol-specific values are unset. Use a dedicated merchant wallet; do not
# reuse the payer/AgentCash wallet.
# Generate one with: cast wallet new
RECIPIENT_WALLET=

# MPP (Tempo USDC). Mainnet Tempo USDC is chain 4217.
# Generate the HMAC key with:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
MPP_SECRET_KEY=
# Mainnet Tempo USDC:
USDC_TEMPO=0x20C000000000000000000000b9537d11c60E8b50
# Optional protocol-specific recipient. Defaults to RECIPIENT_WALLET.
MPP_RECIPIENT=
# Optional hostname to advertise in MPP challenges. Defaults to BASE_URL host.
MPP_REALM=
MPP_TESTNET=false
# Tempo testnet alternative:
# USDC_TEMPO=0x20c0000000000000000000000000000000000000
# MPP_TESTNET=true

# x402 (Base USDC). For mainnet, CDP facilitator credentials are required.
# Optional protocol-specific payee. Defaults to RECIPIENT_WALLET.
X402_PAYEE_ADDRESS=
# Base mainnet:
X402_NETWORK=eip155:8453
X402_FACILITATOR_URL=https://api.cdp.coinbase.com/platform/v2/x402
# Base Sepolia alternative:
# X402_NETWORK=eip155:84532
# X402_FACILITATOR_URL=https://x402.org/facilitator
# CDP keys are required for the Coinbase-hosted Base mainnet facilitator.
CDP_API_KEY_ID=
CDP_API_KEY_SECRET=

# TLS Configuration
# DOMAIN=yourdomain.com
# APP_PORT=3000
# ENABLE_CADDY_LOGS=false
# ACME_STAGING=false
# ACME_FORCE_ISSUE=false
